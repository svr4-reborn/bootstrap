From 15d56c4aa2a49d005343cf81294c2b0c75b17b51 Mon Sep 17 00:00:00 2001
From: Alexander Richards <electrodeyt@gmail.com>
Date: Sun, 14 Jun 2026 02:07:21 +0200
Subject: [PATCH] Use libGL for GLX on sysv4

---
 meson.build | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/meson.build b/meson.build
index c1853f9..927ae91 100644
--- a/meson.build
+++ b/meson.build
@@ -99,7 +99,7 @@ if not dep_glu.found() and host_machine.system() != 'darwin'
 endif
 
 dep_glx = dependency('glx', required: false, disabler : true)
-if not dep_glx.found() and host_machine.system() == 'darwin'
+if not dep_glx.found() and (host_machine.system() == 'darwin' or host_machine.system() == 'sysv4')
   # xquartz doesn't have a glx.pc, but it does have the header. And all the
   # symbols reside in libGL, so let's just use that.
   if cc.check_header('GL/glx.h', dependencies: dep_x11)
-- 
