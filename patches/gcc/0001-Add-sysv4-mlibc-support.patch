+/* Force -fPIC unless the user explicitly disables it with -fno-pic or -fno-PIC */
+#undef CC1_SPEC
+#define CC1_SPEC "%{!fno-pic:%{!fno-PIC:-fPIC}}"
+
+/* Ensure dynamic executables use mlibc's loader.
+   --enable-default-pie adds -pie via GCC's generic link_command, but if we
+   replace LINK_SPEC without a dynamic-linker clause, GNU ld falls back to its
+   i386 SYSV default of /usr/lib/libc.so.1. */
+#undef LINK_SPEC
+#define LINK_SPEC "%{shared:-shared} %{!static:%{!static-pie:%{!shared:-dynamic-linker " GNU_USER_DYNAMIC_LINKER "}}}"
